# Copy this file to .env and fill in your real credentials.
# .env is gitignored — never commit real keys.

AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# Azure Cache for Redis — only needed when not running the local docker-compose Redis.
# Local dev / docker-compose default to localhost:6379 with no auth and no SSL.
REDIS_HOST=your-cache.redis.cache.windows.net
REDIS_PORT=6380
REDIS_KEY=your-redis-primary-key
REDIS_SSL_ENABLED=true
