<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
  xmlns="https://github.com/spotbugs/filter/3.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
    https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

  <!-- Lombok-generated classes expose internal state — not real bugs -->
  <Match>
    <Class name="~.*\.model\..*"/>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
  </Match>
  <Match>
    <Class name="~.*\.dto\..*"/>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
  </Match>

  <!-- Spring Security CSRF disabled intentionally (stateless JWT API) -->
  <Match>
    <Bug pattern="SPRING_CSRF_PROTECTION_DISABLED"/>
  </Match>

  <!-- H2 web console intentionally open for dev -->
  <Match>
    <Bug pattern="SPRING_FILE_DISCLOSURE"/>
  </Match>
</FindBugsFilter>
